    "@nestjs/schematics": "11.0.0",
    "@nestjs/testing": "11.0.1",
    "@swc/cli": "0.6.0",
    "@swc/core": "1.10.15",
    "@types/bcryptjs": "2.4.6",
    "@types/express": "5.0.0",
    "@types/jest": "29.5.14",
    "@types/node": "22.13.1",
    "@types/supertest": "6.0.2",
    "@types/uuid": "^10.0.0",
    "eslint": "9.20.1",
    "eslint-config-prettier": "10.0.1",
