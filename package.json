    "@nestjs/platform-express": "11.0.9",
    "@nestjs/swagger": "11.0.3",
    "@nestjs/testing": "11.0.9",
    "@nestjs/typeorm": "11.0.0",
    "aws-sdk": "2.1692.0",
    "axios": "1.7.9",
    "bcrypt": "5.1.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "fs-extra": "11.3.0",
    "jest": "29.7.0",
    "jsonwebtoken": "9.0.2",
